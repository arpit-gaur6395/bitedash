{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/proxy.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/proxy.js": {
      "runtime": "nodejs18.x"
    }
  },
  "installCommand": "rm -rf node_modules package-lock.json && npm install"
}